@using FLRC.Leaderboards.Model
@using FLRC.Leaderboards.Web.ViewModels
@model ViewModel<Challenge>

<h2>@Model.Title</h2>

<article class="card card-highlighted">
	<section class="card-body">
		<form method="post">
			<div class="row">
				<div class="form-group col-sm-7 col-md-8 col-lg-9 col-xl-10">
					<label for="name">Name</label>
					<input type="text" id="name" name="Name" required value="@Model.Data.Name" class="form-control"/>
				</div>

				<div class="form-group col-sm-5 col-md-4 col-lg-3 col-xl-2">
					<label for="time-limit">Time Limit (Hours)</label>
					<input type="text" inputmode="numeric" id="time-limit" name="TimeLimit" value="@Model.Data.TimeLimit?.TotalHours" class="form-control text-sm-right"/>
				</div>
			</div>

			<h3>Courses</h3>
			<table class="table table-striped table-bordered table-sm table-responsive-sm">
				<thead>
				<tr>
					<th scope="col"></th>
					<th scope="col">Name</th>
					<th scope="col">Type</th>
					<th scope="col">Distance</th>
				</tr>
				</thead>
				<tbody>
				@foreach (var course in Model.Data.Iteration.Races.SelectMany(c => c.Courses).OrderBy(c => c.Distance))
				{
					<tr>
						<td class="text-center align-middle">
							<input type="checkbox" id="course-@course.ID" name="Selected" value="@course.ID" @(Model.Data.Courses.Contains(course) ? "checked" : "")/>
						</td>
						<th scope="row">
							<label for="course-@course.ID" class="form-check-label">@course.Race.Name</label>
						</th>
						<td>@course.Race.Type</td>
						<td>@course.DistanceDisplay</td>
					</tr>
				}
				</tbody>
			</table>

			<button type="submit" class="btn btn-primary">
				Submit
			</button>
			<a href="/Admin/Challenges" class="btn btn-light">
				Cancel
			</a>
		</form>
	</section>
</article>