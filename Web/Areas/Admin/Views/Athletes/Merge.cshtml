@using FLRC.Leaderboards.Web.Areas.Admin
@using FLRC.Leaderboards.Web.Areas.Admin.ViewModels
@model ViewModel<MergeAthletesForm>

<h2>@Model.Title</h2>

<article class="card card-highlighted">
	<section class="card-body">
		<p>This form will perform the following actions:</p>
		<ul>
			<li>All results, series registrations, and linked accounts will be moved from the top athlete to the bottom athlete</li>
			<li>The top athlete's name, category, date of birth, and privacy settings <b>will not</b> move to the bottom athlete</li>
			<li>The top athlete will be <b>deleted</b> from the database</li>
		</ul>

		<form method="post" class="d-flex flex-column align-items-center">
			<div class="form-group">
				<label for="from">
					Merge From:
					<span class="text-danger">(athlete to delete)</span>
				</label>
				<select id="from" name="from" class="form-control">
					@foreach (var athlete in Model.Data.Athletes)
					{
						<option value="@athlete.ID" @(athlete.ID == Model.Data.Current.ID ? "selected" : "")>
							@athlete.Name (@athlete.AgeToday @athlete.Category) &mdash; @athlete.Results.Count results, @athlete.Registrations.Count series registrations, @athlete.LinkedAccounts.Count linked accounts
						</option>
					}
				</select>
			</div>

			<i class="fas fa-2x fa-arrow-down p-3"></i>

			<div class="form-group">
				<label for="to">
					Merge To:
					<span class="text-success">(remaining athlete)</span>
				</label>
				<select id="to" name="to" class="form-control">
					@foreach (var athlete in Model.Data.Athletes)
					{
						<option value="@athlete.ID" @(athlete.ID == Model.Data.Current.ID ? "selected" : "")>
							@athlete.Name (@athlete.AgeToday @athlete.Category) &mdash; @athlete.Results.Count results, @athlete.Registrations.Count series registrations, @athlete.LinkedAccounts.Count linked accounts
						</option>
					}
				</select>
			</div>

			<div class="form-group">
				<button type="submit" class="btn btn-primary">Submit</button>
				<a href="/Admin/Athetes/@Model.Data.Current.ID" class="btn btn-light">Back</a>
			</div>
		</form>
	</section>
</article>