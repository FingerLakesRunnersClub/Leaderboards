@using System.Text.Json
@using FLRC.Leaderboards.Core.Metrics
@using FLRC.Leaderboards.Web.ViewModels
@model ViewModel<AthleteCourseResults<Time>>

@await Component.InvokeAsync("AthleteHeader", Model.Data.Athlete.ID)

<div class="card-highlighted card mb-3">
    <div class="card-header">
        All Efforts for Course
    </div>
    <div class="card-body">
        @await Html.PartialAsync("CourseInfo", Model.Data.Course)

        <script>
            const fields = [
                { name: 'Rank', show: !@Model.Data.Athlete.IsPrivate.ToString().ToLowerInvariant(), center: true, value: r => r.Rank?.Value },
                { name: 'Date', center: true, value: r => r.Result.StartTime, sort: r => r.Result.StartTime },
                { name: 'Time', show: !@Model.Data.Athlete.IsPrivate.ToString().ToLowerInvariant(), center: true, value: r => r.Value.Display, sort: r => r.Value.Value },
                { name: 'Age Grade', show: !@Model.Data.Athlete.IsPrivate.ToString().ToLowerInvariant(), center: true, value: r => r.AgeGrade?.Display, sort: r => r.AgeGrade?.Value, descending: true }
            ];

            const rows = @Html.Raw(JsonSerializer.Serialize(Model.Data.RankedResults));
        </script>

        @await Html.PartialAsync("DataTable", (Model.Title, "sm"))

    </div>
</div>