@using System.Text.Json
@using FLRC.Leaderboards.Core.Metrics
@using FLRC.Leaderboards.Web.ViewModels
@model ViewModel<CourseResults<Time>>

@await Component.InvokeAsync("AddResultButton", Model.Data.Course)
<h2>@Model.Title</h2>

<article class="card card-highlighted">
	<section class="card-body">
		@await Html.PartialAsync("CourseInfo", Model.Data.Course)
		@await Html.PartialAsync("ResultFilter", Model.Data)

		<script>
            const fields = [
                { name: 'Rank', center: true, value: r => r.Rank.Value },
                { name: 'Name', value: r => r.Result.Athlete.Name, link: r => `/Athlete/Index/${r.Result.Athlete.ID}` },
                { name: 'Age', center: true, value: r => r.Result.AthleteAge || '' },
                { name: 'Category', center: true, value: r => r.Result.Athlete.Category, sort: r => r.Result.Athlete.Category ?? 'X', show: @((Model.Data.Filter.Category == null).ToString().ToLowerInvariant()) },
                { name: 'Time', center: true, value: r => r.Value?.Display, sort: r => r.Value?.Value.TotalSeconds },
                { name: 'Age Grade', center: true, value: r => r.AgeGrade?.Display, sort: r => r.AgeGrade?.Value, descending: true },
                { name: 'Behind Leader', center: true, value: r => r.BehindLeader != null ? `+ ${r.BehindLeader.Display}` : null, sort: r => r.BehindLeader?.Value.TotalSeconds },
                { name: 'Points', center: true, value: r => r.Points?.Display, sort: r => r.Points?.Value, descending: true, show: @((Model.Data.Filter.Category != null && Model.Data.Filter.AgeGroup == null).ToString().ToLowerInvariant()) }
            ];

            const rows = @Html.Raw(JsonSerializer.Serialize(Model.Data.Results.Where(r => r.Result.Duration > TimeSpan.Zero)));
        </script>

		@await Html.PartialAsync("DataTable", (Model.Title, "md"))
	</section>
</article>