@using FLRC.Leaderboards.Core.Metrics
@using FLRC.Leaderboards.Core.Races
@using FLRC.Leaderboards.Model
@using FLRC.Leaderboards.Web.ViewModels
@model ViewModel<Result>

<h2>@Model.Title</h2>

<article class="card card-highlighted">
	<section class="card-body">
		<div class="alert alert-danger">
			Are you sure you want to delete this result?
		</div>

		<table class="table table-striped table-bordered">
			<tbody>
			<tr>
				<th scope="row">Course</th>
				<td>@Model.Data.Course.Race.Name</td>
			</tr>
			<tr>
				<th scope="row">Start Time</th>
				<td>@(new Date(Model.Data.StartTime).Display)</td>
			</tr>
			<tr>
				<th scope="row">Duration</th>
				<td>@(new Time(Model.Data.Duration).Display)</td>
			</tr>
			</tbody>
		</table>

		<form method="post">
			<button type="submit" class="btn btn-danger">Confirm</button>
			<a href="javascript:history.back();" class="btn btn-light">Cancel</a>
		</form>
	</section>
</article>