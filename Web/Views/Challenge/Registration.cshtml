@using FLRC.Leaderboards.Model
@using FLRC.Leaderboards.Web.ViewModels
@model ViewModel<Iteration>

<h2>@Model.Title</h2>

<article class="card card-highlighted">
	<section class="card-body">
		<h3>Uh oh!</h3>

		<p>We couldn't find your @Model.Data.Name @Model.Data.Series.Name registration.</p>

		<a class="btn btn-light" href="https://www.webscorer.com/register?pid=1&raceid=@Model.Data.RegistrationContext">
			Register Here
		</a>

		<p>Once you're signed up, click the button below.</p>

		<form method="post">
			<button type="submit" class="btn btn-primary">
				Check again
			</button>
		</form>
	</section>
</article>